generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id        Int      @id @default(autoincrement())
  nome      String
  slug      String   @unique
  descricao String?
  icone     String?
  artigos   Artigo[]
  criadoEm  DateTime @default(now())
}

model Artigo {
  id           Int             @id @default(autoincrement())
  titulo       String
  slug         String          @unique
  descricao    String
  conteudo     String
  imagemCapa   String?
  categoria    Categoria       @relation(fields: [categoriaId], references: [id])
  categoriaId  Int
  produtos     ArtigoProduto[]
  publicado    Boolean         @default(false)
  atualizadoEm DateTime        @updatedAt
  criadoEm     DateTime        @default(now())

  @@index([slug])
  @@index([categoriaId])
  @@index([publicado, criadoEm])
}

model Produto {
  id           Int             @id @default(autoincrement())
  nome         String
  descricao    String?
  imagem       String?
  linkAfiliado LinkAfiliado?
  artigos      ArtigoProduto[]
  criadoEm     DateTime        @default(now())
}

model ArtigoProduto {
  id        Int     @id @default(autoincrement())
  artigo    Artigo  @relation(fields: [artigoId], references: [id], onDelete: Cascade)
  artigoId  Int
  produto   Produto @relation(fields: [produtoId], references: [id])
  produtoId Int
  posicao   Int
  nota      Float?
  destaque  String?
  pros      String?
  contras   String?

  @@unique([artigoId, produtoId])
  @@index([artigoId, posicao])
}

model LinkAfiliado {
  id        Int      @id @default(autoincrement())
  produto   Produto  @relation(fields: [produtoId], references: [id])
  produtoId Int      @unique
  url       String
  cliques   Int      @default(0)
  criadoEm  DateTime @default(now())
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  senha    String
  nome     String?
  criadoEm DateTime @default(now())
}
